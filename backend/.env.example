# ResumeForge backend — copy to .env and fill in.
# Every value here has a safe default except the provider keys, which are
# optional (users can also supply their own key per-request from the UI).

# --- Environment ---
ENVIRONMENT=dev                       # dev | prod
LOG_LEVEL=INFO

# --- CORS --- comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# --- Limits / resilience ---
FILE_TTL_SECONDS=1800                 # how long generated files stay downloadable
MAX_UPLOAD_MB=10                      # max resume upload size
REQUEST_TIMEOUT_S=60                  # per LLM request timeout
LLM_MAX_RETRIES=2                     # retries on transient LLM errors

# --- Optional server-side LLM keys (fallback if user supplies none) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- Optional GitHub token (raises API rate limit 60 -> 5000 req/hr) ---
GITHUB_TOKEN=
